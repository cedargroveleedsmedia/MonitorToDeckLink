<Window x:Class="MonitorToDeckLink.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monitor to DeckLink Output"
        Height="400" Width="520"
        ResizeMode="CanMinimize"
        Background="#1E1E2E"
        Foreground="White"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="BorderBrush" Value="#585B70"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="#E0E0E0" BorderBrush="#585B70" BorderThickness="1"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Padding="8,0,4,0" HorizontalContentAlignment="Left">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="6,0,0,0"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#1E1E2E" VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="8,0,24,0" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#1E1E2E"/>
                                        <Setter Property="FontSize" Value="13"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="#E0E0E0" BorderBrush="#585B70" BorderThickness="1"
                                        MaxHeight="300" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#1E1E2E"/>
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#A6E3A1"/>
                                <Setter Property="Foreground" Value="#1E1E2E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Monitor Selection -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Source Monitor" Style="{StaticResource LabelStyle}"/>
            <ComboBox x:Name="cmbMonitors" Style="{StaticResource ComboStyle}"
                      SelectionChanged="cmbMonitors_SelectionChanged"/>
        </StackPanel>

        <!-- DeckLink Device Selection -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="DeckLink Device" Style="{StaticResource LabelStyle}"/>
            <ComboBox x:Name="cmbDeckLinks" Style="{StaticResource ComboStyle}"
                      SelectionChanged="cmbDeckLinks_SelectionChanged"/>
        </StackPanel>

        <!-- Output Format -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Output Format" Style="{StaticResource LabelStyle}"/>
            <ComboBox x:Name="cmbFormats" Style="{StaticResource ComboStyle}"/>
        </StackPanel>

        <!-- DeckLink Output Channel (Duo has 2 outputs) -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="Output Sub-device (Duo has 2 channels)" Style="{StaticResource LabelStyle}"/>
            <ComboBox x:Name="cmbOutputChannel" Style="{StaticResource ComboStyle}">
                <ComboBoxItem Content="Channel 1 (first listed device)" IsSelected="True"/>
                <ComboBoxItem Content="Channel 2 (second listed device)"/>
            </ComboBox>
            <TextBlock Text="ℹ The DeckLink Duo appears as two separate devices in the list above."
                       Foreground="#6C7086" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Status -->
        <Border Grid.Row="7" Background="#181825" CornerRadius="6" Margin="0,16,0,0" Padding="12,8">
            <TextBlock x:Name="txtStatus" Text="Ready. Select a monitor and DeckLink device, then click Start."
                       Foreground="#A6E3A1" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="8" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnStart" Grid.Column="0" Content="▶  Start Output"
                    Style="{StaticResource ButtonStyle}"
                    Background="#A6E3A1" Foreground="#1E1E2E"
                    Click="btnStart_Click"/>
            <Button x:Name="btnStop" Grid.Column="2" Content="■  Stop Output"
                    Style="{StaticResource ButtonStyle}"
                    Background="#F38BA8" Foreground="#1E1E2E"
                    IsEnabled="False"
                    Click="btnStop_Click"/>
        </Grid>
    </Grid>
</Window>
